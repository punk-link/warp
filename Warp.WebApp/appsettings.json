{
  "ContactEmails": {
    "DataRequestEmail": "data-warp@punk.link",
    "FeedbackEmail": "feedback-warp@punk.link",
    "PrivacyEmail": "privacy-warp@punk.link"
  },
  "EntryValidatorOptions": {
    "MaxPlainTextSize": 262144,
    "MaxHtmlSize": 262144,
    "MaxContentDeltaSize": 524288
  },
  "ImageCacheOptions": {
    "MaxCachableFileSize": 5242880
  },
  "MalwareScanOptions": {
    "ScanTimeoutMs": 10000,
    "PollingIntervalMs": 500
  },
  "ContentModerationOptions": {
    "Endpoint": "https://api.openai.com/v1",
    "Model": "omni-moderation-latest",
    "BatchSize": 10,
    "DelayBetweenBatchesSeconds": 5,
    "FailureBackoffSeconds": 60,
    "FailureThreshold": 5,
    "ProcessingLockSeconds": 60,
    "MetadataRetentionBufferMinutes": 60,
    "InitialConcurrency": 2,
    "MaxConcurrency": 5,
    "SuccessThreshold": 0.95,
    "SuccessRateWindow": "00:01:00",
    "RateLimiter": {
      "CircuitBreakerFailureThreshold": 5,
      "ConcurrencyIncrement": 1,
      "ConcurrencyDecreaseRatio": 0.3,
      "LowSuccessRateMultiplier": 0.9,
      "MinimumConcurrency": 1,
      "MinimumConcurrencyDecrement": 1,
      "MinimumSampleSize": 10
    }
  },
  "FeatureManagement": {
    "ContentModeration": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ServiceName": "warp"
}
