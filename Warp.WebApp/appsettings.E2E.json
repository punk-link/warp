  "Redis": {
    "Host": "warp-keydb"
  },
  "S3Options": {
    "AccessKey": "local-dev",
    "BucketName": "warp-e2e",
    "ForcePathStyle": true,
    "SecretAccessKey": "local-dev",
    "ServiceUrl": "http://warp-s3mock:9090"
  }
}
