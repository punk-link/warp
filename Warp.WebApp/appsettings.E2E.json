{
  "DetailedErrors": true,
  "EncryptionOptions": {
    "TransitKeyName": "warp-end-to-end",
    "Type": "TransitEncryptionService"
  },
  "FeatureManagement": {
    "ContentModeration": false,
    "EntryEncryption": true,
    "MalwareScan": false
  },
  "OpenGraph": {
    "DefaultImageUrl": "https://amazonaws.com/og-default.png"
  },
  "PNKL_VAULT_ADDR": "http://warp-vault:8200",
